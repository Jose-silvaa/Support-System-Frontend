# Copiar para .env e preencher com os valores do projeto.
# Nunca commitar .env (já deve estar no .gitignore).

# URL base da API (ex.: https://api.meuprojeto.com ou http://localhost:3000/api)
VITE_API_BASE_URL=/api

# Nome da aplicação (opcional; usado em configs)
VITE_APP_NAME=Boilerplate React Vite

# Nota: RESEND_API_KEY e RESEND_FROM usam-se apenas no backend (Node),
# não definas aqui para não expor a chave no frontend.
